{
  "compilerOptions": {
    "target": "es2020",
    "lib": ["dom", "dom.iterable", "esnext"],
    "allowJs": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "strict": true,
    "forceConsistentCasingInFileNames": true,
    "noFallthroughCasesInSwitch": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "preserveSymlinks": true,
    "baseUrl": ".",
    "paths": {
      "@/*": ["src/*"],
      "@ownables/platform-browser": [
        "node_modules/@ownables/platform-browser/dist/platform-browser/src/index.d.ts"
      ],
      "@ownables/platform-browser/*": [
        "node_modules/@ownables/platform-browser/dist/platform-browser/src/*"
      ]
    },
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "jsx": "react-jsx"
  },
  "include": ["src"]
}
