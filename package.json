{
  "name": "@ownables/sdk",
  "version": "0.1.0",
  "packageManager": "yarn@4.10.3",
  "license": "MIT",
  "description": "Development tools for Ownables",
  "homepage": "https://ownables.info",
  "dependencies": {
    "@base-ui/react": "^1.3.0",
    "@fontsource/montserrat": "^5.2.8",
    "@ownables/adapter-viem": "^0.5.1",
    "@ownables/builder-client": "^0.5.1",
    "@ownables/core": "^0.5.1",
    "@ownables/platform-browser": "^0.5.1",
    "@rainbow-me/rainbowkit": "^2.2.10",
    "@tanstack/react-query": "^5.90.5",
    "@types/node": "^25.5.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "all-inline": "^0.1.7",
    "axios": "^1.13.6",
    "blockstore-core": "^6.1.2",
    "buffer": "^6.0.3",
    "cbor-x": "^1.6.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "eqty-core": "^1.0.2",
    "ipfs-unixfs-importer": "^16.1.4",
    "jszip": "^3.10.1",
    "lucide-react": "^0.577.0",
    "mime": "^4.1.0",
    "notistack": "^3.0.2",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-json-view": "^1.21.3",
    "tailwind-merge": "^3.5.0",
    "typescript": "^5.9.3",
    "util": "^0.12.5",
    "viem": "^2.47.6",
    "wagmi": "^2.19.5",
    "web-vitals": "^5.1.0"
  },
  "overrides": {
    "react-json-view": {
      "react": "$react",
      "react-dom": "$react-dom"
    }
  },
  "scripts": {
    "start": "vite",
    "dev": "vite",
    "build": "vite build",
    "check:styles": "node bin/check-styles.mjs",
    "preview": "vite preview",
    "test:e2e": "cucumber-js",
    "rustup": "curl https://sh.rustup.rs -sSf | sh; curl https://rustwasm.github.io/wasm-pack/installer/init.sh -sSf | sh; rustup default stable; rustup update stable; rustup target add wasm32-unknown-unknown",
    "ownables:build": "bin/ownables-build.sh",
    "ownables:clean": "rm -rf ./ownables/*.zip ./ownables/target/ ./ownables/*/pkg/ ./ownables/*/schema/ ./ownables/Cargo.lock",
    "ownables:deploy": "cp ./ownables/*.zip ./public/ownables/",
    "ownables:cid": "node bin/package-cid.mjs",
    "typecheck": "tsc --noEmit",
    "ownables:copy": "bin/ownables-copy.sh"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/eqty-dao/ownables-sdk.git"
  },
  "keywords": [
    "webassembly",
    "wasm",
    "rust",
    "webpack"
  ],
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "devDependencies": {
    "@babel/core": "^7.29.0",
    "@babel/preset-typescript": "^7.28.5",
    "@cucumber/cucumber": "^12.7.0",
    "@letsrunit/bdd": "^0.8.0",
    "@letsrunit/cli": "^0.8.0",
    "@letsrunit/cucumber": "^0.8.0",
    "@tailwindcss/postcss": "^4.2.1",
    "@vitejs/plugin-react": "^6.0.1",
    "ajv": "^8.18.0",
    "ajv-keywords": "^5.1.0",
    "autoprefixer": "^10.4.27",
    "postcss": "^8.5.8",
    "tailwindcss": "^4.2.1",
    "vite": "^8.0.0"
  }
}
